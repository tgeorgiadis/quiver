<Window x:Class="Quiver.MainWindow"
		xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:local="clr-namespace:Quiver"
		xmlns:services="clr-namespace:Quiver.Services"
		xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
        Title="Quiver"
		Width="1280" Height="720"
		MinWidth="750" MinHeight="490"
        Background="{Binding WindowBackground}"
		WindowState="Normal"
        WindowStartupLocation="CenterScreen"
		SystemDecorations="Full"
        ExtendClientAreaToDecorationsHint="{Binding ExtendClientAreaEnabled}"
        ExtendClientAreaChromeHints="{Binding ChromeHints}">

	<Window.Resources>
		<local:BooleanToStretchConverter x:Key="BooleanToStretchConverter"/>
		<local:ThicknessConverter x:Key="ThicknessConverter"/>
		<local:DoubleScaleConverter x:Key="DoubleScaleConverter"/>

		<!-- Theme Color Resources -->
		<SolidColorBrush x:Key="ThemeBase" Color="#18181b"/>
		<SolidColorBrush x:Key="ThemeLighter" Color="#252527"/>
		<SolidColorBrush x:Key="ThemeDarker" Color="#0e0e10"/>
		<SolidColorBrush x:Key="ThemeBorder" Color="#2d2d30"/>
		<SolidColorBrush x:Key="ThemeText" Color="White"/>
		<SolidColorBrush x:Key="ThemeTextSecondary" Color="#B8B8B8"/>

		<!-- list view -->
		<DataTemplate x:Key="ListViewTemplate">
			<Border Classes="gamecard" Height="{Binding ElementName=SlotSizeSlider, Path=Value}" Margin="0,0,0,12"
					PointerPressed="GameCard_PointerPressed">
				<Grid ClipToBounds="True">
					<Panel ClipToBounds="True">
						<Border CornerRadius="12" ClipToBounds="True">
							<asyncImageLoader:AdvancedImage Source="{Binding IconUrl}"
								ClipToBounds="True"
								Height="{Binding ElementName=IconSizeSlider, Path=Value}"
								VerticalAlignment="Center"
								HorizontalAlignment="Left"
								Opacity="{Binding ElementName=IconOpacitySlider, Path=Value}"
								Margin="{Binding ElementName=IconMarginSlider, Path=Value, Converter={StaticResource ThicknessConverter}}"
								Stretch="{Binding Path=IsChecked, ElementName=IconFillCheckBox, Converter={StaticResource BooleanToStretchConverter}}" />
						</Border>
					</Panel>
					<Grid Margin="24">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="0" Margin="{Binding ElementName=TextMarginSlider, Path=Value, Converter={StaticResource ThicknessConverter}}" VerticalAlignment="Center">
							<TextBlock Text="{Binding Name}"
									   FontSize="22"
									   FontWeight="Bold"
									   Foreground="{DynamicResource ThemeText}"/>
							
							<TextBlock Text="{Binding StatusText}"
									   FontSize="13"
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   Margin="0,6,0,0"/>
							
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="Latest: "
										   FontSize="12"
										   Foreground="{DynamicResource ThemeTextSecondary}"/>
								
								<TextBlock Text="{Binding LatestVersion}"
										   FontSize="12"
										   Foreground="{DynamicResource ThemeTextSecondary}"/>
							</StackPanel>
							<StackPanel Orientation="Horizontal"
										IsVisible="{Binding HasPreferredVersion}">
								<TextBlock Text="Preferred: "
										   FontSize="12"
										   Foreground="{DynamicResource ThemeTextSecondary}"/>

								<TextBlock Text="{Binding PreferredVersion}"
										   FontSize="12"
										   Foreground="{DynamicResource ThemeTextSecondary}"/>
							</StackPanel>
						</StackPanel>
						
						<!-- Gamecard: Options -->
						<StackPanel Grid.Column="1" 
									Orientation="Horizontal" 
									VerticalAlignment="Center"
									Spacing="12">
							<Button Classes="modern"
									Content="{Binding ButtonText}"
									FontSize="15"
									MinWidth="{Binding ElementName=ActionButtonSizeSlider, Path=Value, Converter={StaticResource DoubleScaleConverter}, ConverterParameter=3.333333}"
									Height="{Binding ElementName=ActionButtonSizeSlider, Path=Value}"
									IsEnabled="{Binding !IsLoading}"
									Click="GameButton_Click"
									Tag="{Binding}"/>

							<Button Classes="options options-listview"
									Content="⋯"
									FontSize="20"
									Height="{Binding ElementName=ActionButtonSizeSlider, Path=Value}"
									Width="{Binding ElementName=ActionButtonSizeSlider, Path=Value}"
									IsEnabled="{Binding !IsLoading}"
									Click="OptionsButton_Click"
									Tag="{Binding}">
								<Button.ContextMenu>
									<ContextMenu>
										<MenuItem Header="Launch"
												  Click="LaunchGameMenu_Click"
												  CommandParameter="{Binding}"
												  IsVisible="{Binding CanLaunch}"/>
										<MenuItem Header="Download"
												  Click="LaunchGameMenu_Click"
												  CommandParameter="{Binding}"
												  IsVisible="{Binding CanDownload}"/>
										<MenuItem Header="Locate Existing Install"
												  Click="LocateExistingInstall_Click"
												  CommandParameter="{Binding}"
												  IsVisible="{Binding CanLocateInstall}"/>
										<MenuItem Header="Update Now"
												  Click="UpdateNowMenu_Click"
												  CommandParameter="{Binding}"
												  IsVisible="{Binding CanUpdate}"/>
										<MenuItem Header="Open Folder"
												  Click="OpenFolder_Click"
												  IsVisible="{Binding IsInstalled}"
												  CommandParameter="{Binding}"/>
										<MenuItem Header="Versions"
												  IsVisible="{Binding CanVersionOptions}">
											<MenuItem Header="Change Version"
													  Click="ChangeVersion_Click"
													  CommandParameter="{Binding}"
													  IsVisible="{Binding CanChangeVersion}"/>
											<MenuItem Header="Skip Update"
													  Click="SkipUpdate_Click"
													  CommandParameter="{Binding}"
													  IsVisible="{Binding CanSkipUpdate}"/>
											<MenuItem Header="Force Update"
													  Click="ForceUpdate_Click"
													  IsVisible="{Binding IsInstalled}"
													  CommandParameter="{Binding}"/>
										</MenuItem>
											<MenuItem Header="Launch Options"
												  IsVisible="{Binding CanLaunchOptions}">
											<MenuItem Header="Select Different Executable" 
													  CommandParameter="{Binding}" 
													  Click="SelectDifferentExecutable_Click"
													  IsVisible="{Binding HasExecutableChoice}"/>
											<MenuItem Header="Create Desktop Shortcut"
													  Click="CreateShortcut_Click"
													  IsVisible="{Binding IsInstalled}"
													  CommandParameter="{Binding}"/>
											<MenuItem Header="Add to Steam"
													  Click="AddToSteam_Click"
													  IsVisible="{Binding IsInstalled}"
													  CommandParameter="{Binding}"/>
										</MenuItem>
										<MenuItem Header="Catalog">
											<MenuItem Header="Edit Entry"
													  Click="EditGameEntry_Click"
													  CommandParameter="{Binding}"/>
											<MenuItem Header="Edit Tags"
													  Click="EditTagsMenu_Click"
													  CommandParameter="{Binding}"/>
											<MenuItem Header="Remove from List"
													  Click="RemoveGameEntry_Click"
													  CommandParameter="{Binding}"
													  IsVisible="{Binding IsInLocalAppsJson}"/>
										</MenuItem>
										<MenuItem Header="Customize">
											<MenuItem Header="Add Custom Image"
													  Click="SetCustomIcon_Click"
													  CommandParameter="{Binding}"/>
											<MenuItem Header="Remove Custom Image"
													  Click="RemoveCustomIcon_Click"
													  CommandParameter="{Binding}"
													  IsVisible="{Binding HasCustomIcon}"/>
											<MenuItem Header="Hide App"
													  Click="HideGame_Click"
													  CommandParameter="{Binding}"/>
										</MenuItem>
										<MenuItem Header="About"
												  IsVisible="{Binding CanInfoOptions}">
											<MenuItem Header="Show Changelog"
													  Click="ShowChangelog_Click"
													  CommandParameter="{Binding}"/>
											<MenuItem Header="Open GitHub Page"
													  Click="OpenGitHubPage_Click"
													  CommandParameter="{Binding}"/>
										</MenuItem>
										<MenuItem Header="Delete"
												  Click="DeleteGameFromLibrary_Click"
												  IsVisible="{Binding IsInstalled}"
												  CommandParameter="{Binding}"/>
									</ContextMenu>
								</Button.ContextMenu>
							</Button>
						</StackPanel>
						<!-- Progress Bar -->
						<Border Grid.ColumnSpan="2"
								VerticalAlignment="Bottom"
								Height="4"
								CornerRadius="0,0,12,12"
								ClipToBounds="True"
								IsVisible="{Binding IsDownloading}">
							<ProgressBar Value="{Binding DownloadProgress}"
										 Minimum="0"
										 Maximum="100"
										 Height="4"
										 Background="Transparent"
										 Foreground="{Binding ProgressBarColor}"
										 BorderThickness="0"/>
						</Border>
					</Grid>
				</Grid>
			</Border>
		</DataTemplate>

		<!-- grid view -->
		<DataTemplate x:Key="GridViewTemplate">
			<StackPanel PointerPressed="GameCard_PointerPressed">
				<Border Classes="gamecardgrid">
					<Border.Width>
						<Binding ElementName="SlotSizeSlider" Path="Value"/>
					</Border.Width>
					<Grid ClipToBounds="True">
						<!-- Background Image -->
						<Panel ClipToBounds="True"
							Margin="{Binding ElementName=IconMarginSlider, Path=Value}"
							VerticalAlignment="Top"
							HorizontalAlignment="Center">
							<Border CornerRadius="12" ClipToBounds="True">
								<asyncImageLoader:AdvancedImage Source="{Binding IconUrl}"
								ClipToBounds="True"
								VerticalAlignment="Center"
								Opacity="{Binding ElementName=IconOpacitySlider, Path=Value}"
								Height="{Binding ElementName=IconSizeSlider, Path=Value}"
								Stretch="{Binding Path=IsChecked, ElementName=IconFillCheckBox, Converter={StaticResource BooleanToStretchConverter}}" />
							</Border>
						</Panel>
						
						<!-- Options Button - Top Right -->
						<Button Classes="options-grid"
								Width="40"
								Height="40"
								FontSize="18"
								VerticalAlignment="Top"
								HorizontalAlignment="Right"
								Margin="12"
								IsEnabled="{Binding !IsLoading}"
								Click="OptionsButton_Click"
								Tag="{Binding}">
							<TextBlock Text="⋯" Foreground="{DynamicResource ThemeText}" TextAlignment="Center" VerticalAlignment="Center"/>
							<Button.ContextMenu>
								<ContextMenu>
									<MenuItem Header="Launch"
											  Click="LaunchGameMenu_Click"
											  CommandParameter="{Binding}"
											  IsVisible="{Binding CanLaunch}"/>
									<MenuItem Header="Download"
											  Click="LaunchGameMenu_Click"
											  CommandParameter="{Binding}"
											  IsVisible="{Binding CanDownload}"/>
									<MenuItem Header="Locate Existing Install"
											  Click="LocateExistingInstall_Click"
											  CommandParameter="{Binding}"
											  IsVisible="{Binding CanLocateInstall}"/>
									<MenuItem Header="Update Now"
											  Click="UpdateNowMenu_Click"
											  CommandParameter="{Binding}"
											  IsVisible="{Binding CanUpdate}"/>
									<MenuItem Header="Open Folder"
											  Click="OpenFolder_Click"
											  IsVisible="{Binding IsInstalled}"
											  CommandParameter="{Binding}"/>
									<MenuItem Header="Versions"
											  IsVisible="{Binding CanVersionOptions}">
										<MenuItem Header="Change Version"
												  Click="ChangeVersion_Click"
												  CommandParameter="{Binding}"
												  IsVisible="{Binding CanChangeVersion}"/>
										<MenuItem Header="Skip Update"
												  Click="SkipUpdate_Click"
												  CommandParameter="{Binding}"
												  IsVisible="{Binding CanSkipUpdate}"/>
										<MenuItem Header="Force Update"
												  Click="ForceUpdate_Click"
												  IsVisible="{Binding IsInstalled}"
												  CommandParameter="{Binding}"/>
									</MenuItem>
									<MenuItem Header="Launch Options"
											  IsVisible="{Binding CanLaunchOptions}">
										<MenuItem Header="Select Different Executable" 
												  CommandParameter="{Binding}" 
												  Click="SelectDifferentExecutable_Click"
												  IsVisible="{Binding HasExecutableChoice}"/>
										<MenuItem Header="Create Desktop Shortcut"
												  Click="CreateShortcut_Click"
												  IsVisible="{Binding IsInstalled}"
												  CommandParameter="{Binding}"/>
										<MenuItem Header="Add to Steam"
												  Click="AddToSteam_Click"
												  IsVisible="{Binding IsInstalled}"
												  CommandParameter="{Binding}"/>
									</MenuItem>
									<MenuItem Header="Catalog">
										<MenuItem Header="Edit Entry"
												  Click="EditGameEntry_Click"
												  CommandParameter="{Binding}"/>
										<MenuItem Header="Edit Tags"
												  Click="EditTagsMenu_Click"
												  CommandParameter="{Binding}"/>
										<MenuItem Header="Remove from List"
												  Click="RemoveGameEntry_Click"
												  CommandParameter="{Binding}"
												  IsVisible="{Binding IsInLocalAppsJson}"/>
									</MenuItem>
									<MenuItem Header="Customize">
										<MenuItem Header="Add Custom Image"
												  Click="SetCustomIcon_Click"
												  CommandParameter="{Binding}"/>
										<MenuItem Header="Remove Custom Image"
												  Click="RemoveCustomIcon_Click"
												  CommandParameter="{Binding}"
												  IsVisible="{Binding HasCustomIcon}"/>
										<MenuItem Header="Hide App"
												  Click="HideGame_Click"
												  CommandParameter="{Binding}"/>
									</MenuItem>
									<MenuItem Header="About"
											  IsVisible="{Binding CanInfoOptions}">
										<MenuItem Header="Show Changelog"
												  Click="ShowChangelog_Click"
												  CommandParameter="{Binding}"/>
										<MenuItem Header="Open GitHub Page"
												  Click="OpenGitHubPage_Click"
												  CommandParameter="{Binding}"/>
									</MenuItem>
									<MenuItem Header="Delete"
											  Click="DeleteGameFromLibrary_Click"
											  IsVisible="{Binding IsInstalled}"
											  CommandParameter="{Binding}"/>
								</ContextMenu>
							</Button.ContextMenu>
						</Button>

						<!-- Progress Bar -->
						<Border VerticalAlignment="Bottom"
								Height="4"
								CornerRadius="0,0,12,12"
								ClipToBounds="True"
								IsVisible="{Binding IsDownloading}">
							<ProgressBar Value="{Binding DownloadProgress}"
										 Minimum="0"
										 Maximum="100"
										 Height="4"
										 Background="Transparent"
										 Foreground="{Binding ProgressBarColor}"
										 BorderThickness="0"/>
						</Border>
					</Grid>
				</Border>
				
				<!-- Info Bar Below Card -->
				<Grid>
					<Grid.Width>
						<Binding ElementName="SlotSizeSlider" Path="Value"/>
					</Grid.Width>
					<Grid Margin="10,0,10,20">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<!-- App name (full width) -->
						<TextBlock Grid.Row="0"
								   Grid.ColumnSpan="2"
								   Text="{Binding Name}"
								   FontSize="14"
								   FontWeight="Bold"
								   Foreground="{DynamicResource ThemeText}"
								   TextAlignment="Left"
								   TextWrapping="Wrap"
								   Margin="0,0,0,4"/>

						<!-- Download/Launch Button -->
						<Button Grid.Row="1"
							Grid.Column="0"
							Classes="modern-icon"
							VerticalAlignment="Top"
							Width="{Binding ElementName=ActionButtonSizeSlider, Path=Value}"
							Height="{Binding ElementName=ActionButtonSizeSlider, Path=Value}"
							Margin="0,0,12,0"
							IsEnabled="{Binding !IsLoading}"
							Click="GameButton_Click"
							Tag="{Binding}">
							<Image Width="{Binding ElementName=ActionButtonSizeSlider, Path=Value}"
								   Source="{Binding ButtonImage}"/>
						</Button>

						<!-- Status and versions -->
						<StackPanel Grid.Row="1"
									Grid.Column="1"
									VerticalAlignment="Center">
							<TextBlock Text="{Binding StatusText}"
									   FontSize="11"
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   TextAlignment="Left"
									   TextWrapping="Wrap"
									   Margin="0,0,0,2"/>

							<TextBlock FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" TextAlignment="Left">
								<Run Text="Latest: "/>
								<Run Text="{Binding LatestVersion}" Foreground="{DynamicResource ThemeTextSecondary}"/>
							</TextBlock>
							<TextBlock FontSize="10"
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   TextWrapping="Wrap"
									   TextAlignment="Left"
									   IsVisible="{Binding HasPreferredVersion}">
								<Run Text="Preferred: "/>
								<Run Text="{Binding PreferredVersion}" Foreground="{DynamicResource ThemeTextSecondary}"/>
							</TextBlock>
						</StackPanel>
					</Grid>
				</Grid>
			</StackPanel>
		</DataTemplate>

		<!-- compact grid view (in-card content) -->
		<DataTemplate x:Key="CompactGridViewTemplate">
			<Border Classes="gamecardcompact"
					PointerPressed="GameCard_PointerPressed">
				<Border.Width>
					<Binding ElementName="SlotSizeSlider" Path="Value"/>
				</Border.Width>
				<Border.MinHeight>
					<Binding ElementName="SlotSizeSlider" Path="Value"/>
				</Border.MinHeight>
				<Grid ClipToBounds="True">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<!-- Icon -->
					<Panel Grid.Row="0"
						   ClipToBounds="True"
						   Margin="{Binding ElementName=IconMarginSlider, Path=Value}"
						   HorizontalAlignment="Center">
						<Border CornerRadius="12,12,0,0" ClipToBounds="True">
							<asyncImageLoader:AdvancedImage Source="{Binding IconUrl}"
								ClipToBounds="True"
								VerticalAlignment="Center"
								HorizontalAlignment="Center"
								Opacity="{Binding ElementName=IconOpacitySlider, Path=Value}"
								Height="{Binding ElementName=IconSizeSlider, Path=Value}"
								Stretch="{Binding Path=IsChecked, ElementName=IconFillCheckBox, Converter={StaticResource BooleanToStretchConverter}}" />
						</Border>
					</Panel>

					<!-- Options Button - Top Right -->
					<Button Classes="options-grid"
							Width="40"
							Height="40"
							FontSize="18"
							VerticalAlignment="Top"
							HorizontalAlignment="Right"
							Margin="12"
							IsEnabled="{Binding !IsLoading}"
							Click="OptionsButton_Click"
							Tag="{Binding}">
						<TextBlock Text="⋯" Foreground="{DynamicResource ThemeText}" TextAlignment="Center" VerticalAlignment="Center"/>
						<Button.ContextMenu>
							<ContextMenu>
								<MenuItem Header="Launch"
										  Click="LaunchGameMenu_Click"
										  CommandParameter="{Binding}"
										  IsVisible="{Binding CanLaunch}"/>
								<MenuItem Header="Download"
										  Click="LaunchGameMenu_Click"
										  CommandParameter="{Binding}"
										  IsVisible="{Binding CanDownload}"/>
								<MenuItem Header="Locate Existing Install"
										  Click="LocateExistingInstall_Click"
										  CommandParameter="{Binding}"
										  IsVisible="{Binding CanLocateInstall}"/>
								<MenuItem Header="Update Now"
										  Click="UpdateNowMenu_Click"
										  CommandParameter="{Binding}"
										  IsVisible="{Binding CanUpdate}"/>
								<MenuItem Header="Open Folder"
										  Click="OpenFolder_Click"
										  IsVisible="{Binding IsInstalled}"
										  CommandParameter="{Binding}"/>
								<MenuItem Header="Versions"
										  IsVisible="{Binding CanVersionOptions}">
									<MenuItem Header="Change Version"
											  Click="ChangeVersion_Click"
											  CommandParameter="{Binding}"
											  IsVisible="{Binding CanChangeVersion}"/>
									<MenuItem Header="Skip Update"
											  Click="SkipUpdate_Click"
											  CommandParameter="{Binding}"
											  IsVisible="{Binding CanSkipUpdate}"/>
									<MenuItem Header="Force Update"
											  Click="ForceUpdate_Click"
											  IsVisible="{Binding IsInstalled}"
											  CommandParameter="{Binding}"/>
								</MenuItem>
								<MenuItem Header="Launch Options"
										  IsVisible="{Binding CanLaunchOptions}">
									<MenuItem Header="Select Different Executable"
											  CommandParameter="{Binding}"
											  Click="SelectDifferentExecutable_Click"
											  IsVisible="{Binding HasExecutableChoice}"/>
									<MenuItem Header="Create Desktop Shortcut"
											  Click="CreateShortcut_Click"
											  IsVisible="{Binding IsInstalled}"
											  CommandParameter="{Binding}"/>
									<MenuItem Header="Add to Steam"
											  Click="AddToSteam_Click"
											  IsVisible="{Binding IsInstalled}"
											  CommandParameter="{Binding}"/>
								</MenuItem>
								<MenuItem Header="Catalog">
									<MenuItem Header="Edit Entry"
											  Click="EditGameEntry_Click"
											  CommandParameter="{Binding}"/>
									<MenuItem Header="Edit Tags"
											  Click="EditTagsMenu_Click"
											  CommandParameter="{Binding}"/>
									<MenuItem Header="Remove from List"
											  Click="RemoveGameEntry_Click"
											  CommandParameter="{Binding}"
											  IsVisible="{Binding IsInLocalAppsJson}"/>
								</MenuItem>
								<MenuItem Header="Customize">
									<MenuItem Header="Add Custom Image"
											  Click="SetCustomIcon_Click"
											  CommandParameter="{Binding}"/>
									<MenuItem Header="Remove Custom Image"
											  Click="RemoveCustomIcon_Click"
											  CommandParameter="{Binding}"
											  IsVisible="{Binding HasCustomIcon}"/>
									<MenuItem Header="Hide App"
											  Click="HideGame_Click"
											  CommandParameter="{Binding}"/>
								</MenuItem>
								<MenuItem Header="About"
										  IsVisible="{Binding CanInfoOptions}">
									<MenuItem Header="Show Changelog"
											  Click="ShowChangelog_Click"
											  CommandParameter="{Binding}"/>
									<MenuItem Header="Open GitHub Page"
											  Click="OpenGitHubPage_Click"
											  CommandParameter="{Binding}"/>
								</MenuItem>
								<MenuItem Header="Delete"
										  Click="DeleteGameFromLibrary_Click"
										  IsVisible="{Binding IsInstalled}"
										  CommandParameter="{Binding}"/>
							</ContextMenu>
						</Button.ContextMenu>
					</Button>

					<!-- App name, status, and action button -->
					<Grid Grid.Row="2" Margin="10,0,10,10">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<TextBlock Grid.Row="0"
								   Grid.ColumnSpan="2"
								   Text="{Binding Name}"
								   FontSize="14"
								   FontWeight="Bold"
								   Foreground="{DynamicResource ThemeText}"
								   TextWrapping="Wrap"
								   Margin="0,0,0,4"/>

						<Button Grid.Row="1"
								Grid.Column="0"
								Classes="modern-icon"
								VerticalAlignment="Top"
								Width="{Binding ElementName=ActionButtonSizeSlider, Path=Value}"
								Height="{Binding ElementName=ActionButtonSizeSlider, Path=Value}"
								Margin="0,0,12,0"
								IsEnabled="{Binding !IsLoading}"
								Click="GameButton_Click"
								Tag="{Binding}">
							<Image Width="{Binding ElementName=ActionButtonSizeSlider, Path=Value}"
								   Source="{Binding ButtonImage}"/>
						</Button>

						<StackPanel Grid.Row="1"
									Grid.Column="1"
									VerticalAlignment="Center">
							<TextBlock Text="{Binding StatusText}"
									   FontSize="11"
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   TextWrapping="Wrap"
									   Margin="0,0,0,2"/>

							<TextBlock FontSize="10"
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   TextWrapping="Wrap">
								<Run Text="Latest: "/>
								<Run Text="{Binding LatestVersion}" Foreground="{DynamicResource ThemeTextSecondary}"/>
							</TextBlock>
							<TextBlock FontSize="10"
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   TextWrapping="Wrap"
									   IsVisible="{Binding HasPreferredVersion}">
								<Run Text="Preferred: "/>
								<Run Text="{Binding PreferredVersion}" Foreground="{DynamicResource ThemeTextSecondary}"/>
							</TextBlock>
						</StackPanel>
					</Grid>

					<!-- Progress Bar -->
					<Border Grid.RowSpan="3"
							VerticalAlignment="Bottom"
							Height="4"
							CornerRadius="0,0,12,12"
							ClipToBounds="True"
							IsVisible="{Binding IsDownloading}">
						<ProgressBar Value="{Binding DownloadProgress}"
									 Minimum="0"
									 Maximum="100"
									 Height="4"
									 Background="Transparent"
									 Foreground="{Binding ProgressBarColor}"
									 BorderThickness="0"/>
					</Border>
				</Grid>
			</Border>
		</DataTemplate>

		<!-- Catalog sync field diff (shared) -->
		<DataTemplate x:Key="CatalogFieldDiffTemplate" DataType="services:CatalogSyncFieldDiffItem">
			<Grid ColumnDefinitions="64,*" Margin="0,0,0,4">
				<TextBlock Grid.Column="0"
						   Text="{Binding FieldLabel}"
						   FontSize="10"
						   FontWeight="SemiBold"
						   Foreground="{DynamicResource ThemeTextSecondary}"
						   VerticalAlignment="Top"
						   Margin="0,2,8,0"/>
				<StackPanel Grid.Column="1" Spacing="2">
					<!-- Text: local → external on one row -->
					<WrapPanel IsVisible="{Binding IsTextValueDiff}" Orientation="Horizontal">
						<TextBlock Text="{Binding LocalValue}"
								   FontSize="10"
								   Foreground="#F0A080"
								   TextDecorations="Strikethrough"
								   TextWrapping="Wrap"
								   Margin="0,0,6,2"
								   IsVisible="{Binding HasLocalValue}"/>
						<TextBlock Text="(empty)"
								   FontSize="10"
								   Foreground="#F0A080"
								   FontStyle="Italic"
								   Margin="0,0,6,2"
								   IsVisible="{Binding ShowEmptyLocal}"/>
						<TextBlock Text="→"
								   FontSize="10"
								   Foreground="{DynamicResource ThemeTextSecondary}"
								   Margin="0,0,6,2"
								   VerticalAlignment="Center"
								   IsVisible="{Binding ShowArrow}"/>
						<TextBlock Text="{Binding ExternalValue}"
								   FontSize="10"
								   Foreground="#6EE7A0"
								   TextWrapping="Wrap"
								   Margin="0,0,0,2"
								   IsVisible="{Binding HasExternalValue}"/>
						<TextBlock Text="(empty)"
								   FontSize="10"
								   Foreground="#6EE7A0"
								   FontStyle="Italic"
								   IsVisible="{Binding ShowEmptyExternal}"/>
					</WrapPanel>
					<!-- Icon: compact side-by-side, URLs in tooltips only -->
					<StackPanel IsVisible="{Binding IsIconDiff}" Orientation="Horizontal" Spacing="8">
						<Border BorderBrush="#F0A080" BorderThickness="1" CornerRadius="4" Padding="2"
								Background="#1A1A1A" IsVisible="{Binding HasLocalValue}"
								ToolTip.Tip="{Binding LocalValue}">
							<asyncImageLoader:AdvancedImage Source="{Binding LocalValue}" Width="36" Height="36" Stretch="Uniform"/>
						</Border>
						<TextBlock Text="→" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"
								   VerticalAlignment="Center" IsVisible="{Binding ShowArrow}"/>
						<Border BorderBrush="#6EE7A0" BorderThickness="1" CornerRadius="4" Padding="2"
								Background="#1A1A1A" IsVisible="{Binding HasExternalValue}"
								ToolTip.Tip="{Binding ExternalValue}">
							<asyncImageLoader:AdvancedImage Source="{Binding ExternalValue}" Width="36" Height="36" Stretch="Uniform"/>
						</Border>
					</StackPanel>
					<ItemsControl IsVisible="{Binding IsTagDiff}" ItemsSource="{Binding TagDiffs}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel Orientation="Horizontal"/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate DataType="services:CatalogSyncTagDiffItem">
								<Border Background="{Binding BackgroundBrush}" CornerRadius="3" Padding="4,1" Margin="0,0,3,2" ToolTip.Tip="{Binding Tooltip}">
									<TextBlock Text="{Binding Tag}" FontSize="9" Foreground="{Binding ForegroundBrush}"/>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Grid>
		</DataTemplate>

		<!-- Catalog review app card -->
		<DataTemplate x:Key="CatalogReviewCardTemplate">
			<Border Background="{DynamicResource ThemeBase}"
					BorderBrush="{DynamicResource ThemeBorder}"
					BorderThickness="1"
					CornerRadius="6"
					Padding="8,6"
					Margin="0,0,0,6">
				<StackPanel Spacing="4">
					<Grid ColumnDefinitions="Auto,*,Auto">
						<Border Grid.Column="0" CornerRadius="6" ClipToBounds="True" Width="44" Height="44" Margin="0,0,10,0">
							<asyncImageLoader:AdvancedImage Source="{Binding IconUrl}" Width="44" Height="44" Stretch="Uniform"/>
						</Border>
						<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
							<StackPanel Orientation="Horizontal" Spacing="8">
								<TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"
										   TextTrimming="CharacterEllipsis"/>
								<Border Background="{DynamicResource ThemeLighter}" CornerRadius="3" Padding="4,1" VerticalAlignment="Center">
									<TextBlock Text="{Binding StatusShortLabel}" FontSize="9" Foreground="{DynamicResource ThemeTextSecondary}"/>
								</Border>
							</StackPanel>
							<TextBlock Text="{Binding Repository}" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}"
									   TextTrimming="CharacterEllipsis"/>
						</StackPanel>
						<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
							<Button Classes="options" Content="Add" Tag="{Binding Repository}" Click="CatalogSyncRowAdd_Click"
									FontSize="10" Padding="6,2" IsVisible="{Binding CanAdd}"/>
							<Button Classes="options" Content="Replace" Tag="{Binding Repository}" Click="CatalogSyncRowReplace_Click"
									FontSize="10" Padding="6,2" IsVisible="{Binding CanReplace}"/>
							<Button Classes="options" Content="Merge" Tag="{Binding Repository}" Click="CatalogSyncRowMerge_Click"
									FontSize="10" Padding="6,2" IsVisible="{Binding CanMerge}"/>
							<Button Classes="options" Content="Ignore" Tag="{Binding Repository}" Click="CatalogSyncRowIgnore_Click"
									FontSize="10" Padding="6,2" IsVisible="{Binding CanIgnore}"/>
							<Button Classes="options" Content="Hide" Tag="{Binding Repository}" Click="CatalogSyncRowHide_Click"
									FontSize="10" Padding="6,2" IsVisible="{Binding ShowHideButton}"/>
							<Button Classes="options" Content="Unhide" Tag="{Binding Repository}" Click="CatalogSyncRowUnhide_Click"
									FontSize="10" Padding="6,2" IsVisible="{Binding ShowUnhideButton}"/>
						</StackPanel>
					</Grid>
					<Border IsVisible="{Binding HasInlineDiff}"
							BorderBrush="{DynamicResource ThemeBorder}"
							BorderThickness="0,1,0,0"
							Padding="0,4,0,0"
							Margin="54,0,0,0">
						<ItemsControl ItemsSource="{Binding FieldDiffs}">
							<ItemsControl.ItemTemplate>
								<StaticResource ResourceKey="CatalogFieldDiffTemplate"/>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</Border>
				</StackPanel>
			</Border>
		</DataTemplate>

		<!-- Catalog source card -->
		<DataTemplate x:Key="CatalogSourceCardTemplate">
			<Border Background="{DynamicResource ThemeBase}"
					BorderBrush="{DynamicResource ThemeBorder}"
					BorderThickness="1"
					CornerRadius="8"
					Padding="14"
					Margin="0,0,0,10">
				<StackPanel Spacing="6">
					<Grid ColumnDefinitions="*,Auto">
						<TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource ThemeText}"/>
						<Border Grid.Column="1" Background="{DynamicResource ThemeLighter}" CornerRadius="10"
								MinWidth="22" Height="22" Padding="6,0" VerticalAlignment="Center"
								IsVisible="{Binding PendingReviewBadgeVisible}">
							<TextBlock Text="{Binding PendingReviewCount}" FontSize="11" FontWeight="Bold"
									   HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
					</Grid>
					<TextBlock Text="{Binding Location}" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap"/>
					<TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap"/>
					<Grid ColumnDefinitions="*,Auto">
						<CheckBox Grid.Column="0" Content="Enabled" IsChecked="{Binding Enabled}" Foreground="{DynamicResource ThemeText}"
								  Tag="{Binding SourceId}" Checked="CatalogSourceEnabled_Changed" Unchecked="CatalogSourceEnabled_Changed"/>
						<Button Grid.Column="1" Classes="options" Content="Remove" Tag="{Binding SourceId}"
								Click="RemoveCatalogSource_Click" FontSize="11" Padding="8,4"/>
					</Grid>
					<Button Classes="options" Content="{Binding ReviewButtonText}" HorizontalAlignment="Stretch"
							Tag="{Binding SourceId}" Click="ReviewCatalogSource_Click" FontSize="12" Margin="0,4,0,0"/>
				</StackPanel>
			</Border>
		</DataTemplate>
	</Window.Resources>

	<Window.Styles>
	<Style Selector="Button.modern">
		<Setter Property="Background" Value="{Binding ButtonColor}"/>
		<Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
		<Setter Property="HorizontalContentAlignment" Value="Center"/>
		<Setter Property="VerticalContentAlignment" Value="Center"/>
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="Padding" Value="20,10"/>
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="Cursor" Value="Hand"/>
		<Setter Property="Template">
			<ControlTemplate TargetType="Button">
				<Border Background="{TemplateBinding Background}"
						CornerRadius="6"
						Padding="{TemplateBinding Padding}">
					<ContentPresenter
						Name="PART_ContentPresenter"
						Content="{TemplateBinding Content}"
						ContentTemplate="{TemplateBinding ContentTemplate}"
						HorizontalAlignment="Center"
						VerticalAlignment="Center"
						Foreground="{TemplateBinding Foreground}"
						FontSize="{TemplateBinding FontSize}"
						FontWeight="{TemplateBinding FontWeight}"/>
				</Border>
			</ControlTemplate>
		</Setter>
	</Style>

	<!-- ComboBox Style -->
	<Style Selector="ComboBox">
		<Setter Property="Background" Value="{DynamicResource ThemeDarker}"/>
		<Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="CornerRadius" Value="4"/>
		<Setter Property="Padding" Value="12,8"/>
	</Style>

	<Style Selector="ComboBox:pointerover /template/ Border#Background">
		<Setter Property="Background" Value="{DynamicResource ThemeLighter}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
	</Style>

	<Style Selector="ComboBox:focus /template/ Border#Background">
		<Setter Property="Background" Value="{DynamicResource ThemeDarker}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
	</Style>

	<Style Selector="ComboBoxItem">
		<Setter Property="Background" Value="{DynamicResource ThemeDarker}"/>
		<Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
		<Setter Property="Padding" Value="12,8"/>
	</Style>

	<Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="{DynamicResource ThemeLighter}"/>
	</Style>

	<Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
		<Setter Property="Background" Value="{DynamicResource ThemeBase}"/>
		<Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
	</Style>

	<Style Selector="Button.modern:pointerover">
		<Setter Property="Opacity" Value="0.85"/>
		<Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
	</Style>

	<Style Selector="Button.modern:pressed">
		<Setter Property="Opacity" Value="0.7"/>
		<Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
	</Style>

	<Style Selector="Button.modern /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Background" Value="Transparent"/>
	</Style>

	<Style Selector="Button.modern:pointerover /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Background" Value="Transparent"/>
	</Style>

	<Style Selector="Button.modern:pressed /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Background" Value="Transparent"/>
	</Style>

	<!-- Modern Icon Button Style for Grid View -->
	<Style Selector="Button.modern-icon">
		<Setter Property="Background" Value="{Binding ButtonColor}"/>
		<Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
		<Setter Property="HorizontalContentAlignment" Value="Center"/>
		<Setter Property="VerticalContentAlignment" Value="Center"/>
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="Padding" Value="0"/>
		<Setter Property="Cursor" Value="Hand"/>
		<Setter Property="Template">
			<ControlTemplate TargetType="Button">
				<Border Background="{TemplateBinding Background}"
						CornerRadius="8"
						Padding="{TemplateBinding Padding}">
					<ContentPresenter
						Name="PART_ContentPresenter"
						Content="{TemplateBinding Content}"
						ContentTemplate="{TemplateBinding ContentTemplate}"
						HorizontalAlignment="Center"
						VerticalAlignment="Center"
						Foreground="{TemplateBinding Foreground}"/>
				</Border>
			</ControlTemplate>
		</Setter>
	</Style>

	<Style Selector="Button.modern-icon:pointerover">
		<Setter Property="Opacity" Value="0.85"/>
		<Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
	</Style>

	<Style Selector="Button.modern-icon:pressed">
		<Setter Property="Opacity" Value="0.7"/>
		<Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
	</Style>

	<Style Selector="Button.modern-icon /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Background" Value="Transparent"/>
	</Style>

	<Style Selector="Button.modern-icon:pointerover /template/ ContentPresenter#PART_ContentPresenter">
