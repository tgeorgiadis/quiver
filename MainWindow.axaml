	<Style Selector="Button.display-filter-overflow">
		<Setter Property="Opacity" Value="0"/>
		<Setter Property="IsHitTestVisible" Value="False"/>
	</Style>

	<Style Selector="Button.display-filter-row:pointerover Button.display-filter-overflow, Button.display-filter-row:focus-within Button.display-filter-overflow, Button.display-filter-row.dragging Button.display-filter-overflow">
		<Setter Property="Opacity" Value="1"/>
		<Setter Property="IsHitTestVisible" Value="True"/>
	</Style>

	<Style Selector="Border.display-filter-reorder">
		<Setter Property="Opacity" Value="0"/>
		<Setter Property="IsHitTestVisible" Value="False"/>
		<Setter Property="Cursor" Value="SizeAll"/>
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="ToolTip.Tip" Value="Drag to reorder"/>
		<Setter Property="ToolTip.ShowDelay" Value="1000"/>
		<Setter Property="ToolTip.BetweenShowDelay" Value="-1"/>
	</Style>

	<Style Selector="Button.display-filter-row:pointerover Border.display-filter-reorder, Button.display-filter-row:focus-within Border.display-filter-reorder, Button.display-filter-row.dragging Border.display-filter-reorder">
