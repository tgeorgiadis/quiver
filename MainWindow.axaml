	<!-- Focus Visual Styles -->
	<Style Selector="Button:focus">
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
		<Setter Property="BorderThickness" Value="2"/>
	</Style>

	<Style Selector="Button:focus /template/ Border">
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
		<Setter Property="BorderThickness" Value="2"/>
	</Style>

	<Style Selector="Button.modern:focus /template/ Border">
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
		<Setter Property="BorderThickness" Value="3"/>
		<Setter Property="Margin" Value="-1"/>
	</Style>

	<Style Selector="Button.modern-icon:focus /template/ Border">
		<Setter Property="BorderThickness" Value="0"/>
	</Style>

	<Style Selector="Button.modern-icon:focus-visible /template/ Border">
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
		<Setter Property="BorderThickness" Value="3"/>
		<Setter Property="Margin" Value="-1"/>
	</Style>

	<Style Selector="Button.options:focus /template/ Border">
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
		<Setter Property="BorderThickness" Value="2"/>
	</Style>

	<Style Selector="Button.options-grid:focus-visible /template/ Border">
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
		<Setter Property="BorderThickness" Value="3"/>
	</Style>

	<Style Selector="Button.options-grid:focus-visible">
		<Setter Property="Opacity" Value="1"/>
		<Setter Property="Background" Value="{DynamicResource ThemeLighter}"/>
	</Style>

	<Style Selector="Button.settings:focus">
		<Setter Property="Background" Value="{DynamicResource ThemeLighter}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
		<Setter Property="BorderThickness" Value="2"/>
		<Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
	</Style>

	<Style Selector="Button.iconbutton:focus">
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
		<Setter Property="BorderThickness" Value="2"/>
	</Style>

	<Style Selector="CheckBox:focus /template/ Border#NormalRectangle">
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
		<Setter Property="BorderThickness" Value="2"/>
	</Style>

	<Style Selector="Slider:focus /template/ Thumb">
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
		<Setter Property="BorderThickness" Value="3"/>
	</Style>

	<Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
		<Setter Property="BorderThickness" Value="2"/>
	</Style>

	<!-- Theme-aware text styles -->
	<Style Selector="TextBlock.theme-text">
		<Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
	</Style>

	<Style Selector="TextBlock.theme-text-secondary">
		<Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
	</Style>

	<Style Selector="TextBlock.theme-text-muted">
		<Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
		<Setter Property="Opacity" Value="0.7"/>
	</Style>

	<Style Selector="TabItem">
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
		<Setter Property="Padding" Value="14,4"/>
		<Setter Property="Margin" Value="4,8,4,0"/>
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="CornerRadius" Value="6"/>
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="MinHeight" Value="42"/>
		<Setter Property="Cursor" Value="Hand"/>
	</Style>

	<Style Selector="TabItem:selected">
		<Setter Property="Background" Value="{DynamicResource ThemeLighter}"/>
		<Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
		<Setter Property="BorderThickness" Value="0"/>
	</Style>

	<Style Selector="TabItem:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="{DynamicResource ThemeBase}"/>
		<Setter Property="TextBlock.Foreground" Value="{DynamicResource ThemeText}"/>
	</Style>

	<Style Selector="TabItem:selected:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="{DynamicResource ThemeLighter}"/>
		<Setter Property="TextBlock.Foreground" Value="{DynamicResource ThemeText}"/>
	</Style>

</Window.Styles>

<Border CornerRadius="24" ClipToBounds="True" Background="Transparent">
	<Grid x:Name="MainGrid">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="240"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- Left Sidebar Navigation -->
		<Border Grid.Column="0" Background="{DynamicResource ThemeDarker}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,1,0">
			<Grid Margin="0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>	
				</Grid.RowDefinitions>

				<!-- Logo/Header -->
				<StackPanel Grid.Row="0"
							Margin="20"
							Orientation="Horizontal"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							Spacing="6">
					<Image Source="avares://Quiver/Assets/app.png"
						   Width="45.75"
						   Height="95.25"
						   VerticalAlignment="Center"/>
					<TextBlock Text="QUIVER"
							   FontSize="18"
							   FontWeight="Bold"
							   Foreground="{DynamicResource ThemeText}"
							   VerticalAlignment="Center"
							   Margin="20,0,0,0"
							   LetterSpacing="2"/>
				</StackPanel>

				<!-- Navigation Buttons -->
				<StackPanel Grid.Row="1" Margin="12,0" VerticalAlignment="Top">

						<!-- Continue Button -->
						<Button x:Name="ContinueButton"
								Classes="settings"
								Margin="0,0,0,4"
								CornerRadius="8"
								Width="216"
								Height="64"
								HorizontalAlignment="Left"
								Click="ContinueButton_Click"
								IsVisible="{Binding IsContinueVisible}">
							<Grid ColumnDefinitions="*,Auto">
								<StackPanel Grid.Column="0"
											Orientation="Horizontal"
											VerticalAlignment="Center">
									<Image Width="32" Height="32" 
										   Source="avares://Quiver/Assets/Continue.png"
										   Margin="0,0,12,0"/>
									<TextBlock Text="Continue" 
											  VerticalAlignment="Center"/>
								</StackPanel>
								<Border Grid.Column="1"
										ClipToBounds="True"
										MaxWidth="48"
										MaxHeight="44"
										Margin="8,0,0,0"
										VerticalAlignment="Center"
										HorizontalAlignment="Right">
									<asyncImageLoader:AdvancedImage Source="{Binding ContinueGameInfo.DefaultIconUrl}"
																	Stretch="Uniform"
																	MaxWidth="48"
																	MaxHeight="44"/>
								</Border>
							</Grid>
						</Button>

						<!-- Library Button -->
						<Button x:Name="LibraryNavButton"
								Classes="settings selected"
								Margin="0,0,0,4"
								CornerRadius="8"
								Width="216"
								HorizontalAlignment="Left"
								Click="LibraryNavButton_Click">
							<StackPanel Orientation="Horizontal">
								<Image Width="32" Height="32"
									   Source="avares://Quiver/Assets/DefaultGame.png"
									   Margin="0,0,12,0"/>
								<TextBlock Text="Library" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>

						<!-- App Catalog Button -->
						<Button x:Name="AppCatalogNavButton"
								Classes="settings"
								Margin="0,0,0,4"
								CornerRadius="8"
								Width="216"
								HorizontalAlignment="Left"
								Click="AppCatalogNavButton_Click">
							<Grid ColumnDefinitions="*,Auto">
								<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
									<Image Width="32" Height="32"
										   Source="avares://Quiver/Assets/AppCatalog.png"
										   Margin="0,0,12,0"/>
									<TextBlock Text="App Catalog" VerticalAlignment="Center"/>
								</StackPanel>
								<Border Grid.Column="1"
										Background="{DynamicResource ThemeLighter}"
										CornerRadius="10"
										MinWidth="20"
										Height="20"
										Padding="6,0"
										VerticalAlignment="Center"
										IsVisible="{Binding CatalogReviewBadgeVisible}">
									<TextBlock Text="{Binding CatalogReviewBadgeCount}"
											   FontSize="11"
											   FontWeight="Bold"
											   HorizontalAlignment="Center"
											   VerticalAlignment="Center"/>
								</Border>
							</Grid>
						</Button>
					</StackPanel>

				<!-- Library-only filters -->
				<Grid x:Name="LibraryFiltersPanel" Grid.Row="2" Grid.RowSpan="2" RowDefinitions="Auto,*">
				<StackPanel Grid.Row="0" Margin="0,4,0,8">
					<Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,0,0,8"/>
					<TextBlock Text="SHOW"
							   FontSize="10"
							   FontWeight="Bold"
							   Foreground="{DynamicResource ThemeTextSecondary}"
							   LetterSpacing="1"
							   Margin="24,0,0,4"/>
				</StackPanel>

				<!-- Filter Buttons ScrollViewer -->
				<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="12,0,12,0">

							<Button x:Name="UnhideAllGamesButton"
									Classes="settings scope-filter"
									Width="216"
									HorizontalAlignment="Left"
									Click="UnhideAllGamesButton_Click">
								<TextBlock Text="All Apps"/>
							</Button>

							<Button x:Name="HideNonInstalledButton"
									Classes="settings scope-filter"
									Width="216"
									HorizontalAlignment="Left"
									Click="HideNonInstalledButton_Click">
								<TextBlock Text="Installed Only"/>
							</Button>

							<Border Height="1"
									Background="{DynamicResource ThemeBorder}"
									Margin="0,8,0,8"/>

							<Grid ColumnDefinitions="*,Auto" Margin="12,0,8,8">
								<TextBlock Grid.Column="0"
										   Text="TAG FILTERS"
										   FontSize="10"
										   FontWeight="Bold"
										   Foreground="{DynamicResource ThemeTextSecondary}"
										   LetterSpacing="1"
										   VerticalAlignment="Center"/>
								<Button Grid.Column="1"
										Classes="iconbutton tag-filter-add"
										Width="24"
										Height="24"
										ToolTip.Tip="Add tag filter"
										Click="AddDisplayFilter_Click">
									<TextBlock Text="+"
											   FontSize="16"
											   FontWeight="Bold"
											   HorizontalAlignment="Center"
											   VerticalAlignment="Center"
											   TextAlignment="Center"/>
								</Button>
							</Grid>

							<ItemsControl x:Name="TagDisplayFiltersItemsControl"
										  ItemsSource="{Binding TagDisplayFilters}">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Button Classes="settings display-filter-row"
												Classes.selected="{Binding IsSelected}"
												Margin="0,0,0,4"
												HorizontalAlignment="Stretch"
												HorizontalContentAlignment="Stretch"
												Click="TagDisplayFilterButton_Click"
												Tag="{Binding Id}">
											<Grid ColumnDefinitions="*,Auto,Auto">
													<TextBlock Grid.Column="0"
															   Text="{Binding Name}"
															   TextTrimming="CharacterEllipsis"
															   VerticalAlignment="Center"/>
													<Border Grid.Column="1"
															Classes="display-filter-reorder"
															Width="28"
															Height="28"
															Margin="4,0,0,0"
															VerticalAlignment="Center"
															Tag="{Binding Id}"
															PointerPressed="TagDisplayFilterReorder_PointerPressed">
														<TextBlock Text="↕"
																   FontSize="14"
																   IsHitTestVisible="False"
																   HorizontalAlignment="Center"
																   VerticalAlignment="Center"/>
													</Border>
													<Button Grid.Column="2"
															Classes="options options-listview display-filter-overflow"
															Content="⋯"
															FontSize="18"
															Width="28"
															Height="28"
															Padding="0"
															Margin="2,0,0,0"
															VerticalAlignment="Center"
															Click="DisplayFilterOverflow_Click"
															Tag="{Binding Id}">
														<Button.ContextMenu>
															<ContextMenu>
																<MenuItem Header="Edit"
																		  Tag="{Binding Id}"
																		  Click="EditTagDisplayFilter_Click"/>
																<MenuItem Header="Delete"
																		  Tag="{Binding Id}"
																		  Click="DeleteTagDisplayFilter_Click"/>
															</ContextMenu>
														</Button.ContextMenu>
													</Button>
												</Grid>
										</Button>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>

							<Button Classes="options"
									Content="Add Display Filter"
									HorizontalAlignment="Stretch"
									Margin="0,8,0,0"
									Click="AddDisplayFilter_Click"/>
						</StackPanel>
				</ScrollViewer>
				</Grid>

				<!-- Footer Links -->
				<StackPanel Grid.Row="4" Margin="12,0,12,8">
						<Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="-12,0,-12,8"/>
					<Button Classes="iconbutton"
							Width="216"
							Height="44"
							HorizontalAlignment="Left"
							Click="GithubButton_Click">
						<StackPanel Orientation="Horizontal" Margin="12,0">
							<Image Width="32" Height="32" 
								   Source="avares://Quiver/Assets/Github.png"
								   Margin="0,0,12,0"/>
							<TextBlock Text="GitHub" 
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   FontSize="14"
									   FontWeight="Medium"
									   VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Main Content Area -->
		<Grid Grid.Column="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- Top Bar -->
			<Border Grid.Row="0" 
					Background="{DynamicResource ThemeDarker}" 
					BorderBrush="{DynamicResource ThemeBorder}"
					BorderThickness="0,0,0,1"
					Padding="0,8,0,8"
					ZIndex="1"
					PointerPressed="TopBar_PointerPressed">
				<Grid VerticalAlignment="Top">
					<TextBlock x:Name="HeaderTitleText"
							   Text="Library"
							   FontSize="24"
							   Margin="15,0,0,0"
							   FontWeight="Bold"
							   Foreground="{DynamicResource ThemeText}"
							   VerticalAlignment="Center"/>
					    <StackPanel Orientation="Horizontal"
						       HorizontalAlignment="Right"
							   VerticalAlignment="Center">

							<StackPanel x:Name="LibraryTopBarPanel" Orientation="Horizontal">
							<Button x:Name="AddNewEntryButton"
									Classes="options"
									Content="+ Add New Entry"
									FontSize="13"
									Margin="0,0,16,0"
									Click="AddNewEntryButton_Click"/>

							<!-- Sorting ComboBox -->	
							<TextBlock Text="Sort by:" 
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   FontSize="14"
									   FontWeight="Medium"
									   VerticalAlignment="Center"/>
							<ComboBox x:Name="SortByComboBox"
									  Foreground="{DynamicResource ThemeTextSecondary}"
									  Background="{DynamicResource ThemeDarker}"
									  BorderBrush="{DynamicResource ThemeBorder}"
									  Margin="4,1,64,0"
									  SelectionChanged="SortByComboBox_SelectionChanged">
								<ComboBoxItem Content="Name (A-Z)" Tag="Name"/>
								<ComboBoxItem Content="Name (Z-A)" Tag="NameDesc"/>
								<ComboBoxItem Content="Installed First" Tag="Installed"/>
								<ComboBoxItem Content="Not Installed First" Tag="NotInstalled"/>
								<ComboBoxItem Content="Last Played" Tag="LastPlayed"/>
							</ComboBox>
							</StackPanel>

							<Button x:Name="CatalogReviewBackButton"
									Classes="options"
									Content="← Back to sources"
									FontSize="13"
									Margin="0,0,16,0"
									IsVisible="False"
									Click="CatalogReviewBack_Click"/>

							<!-- Version Text -->
							<TextBlock Grid.Row="0"
								   Text="{Binding currentVersionString}"
								   VerticalAlignment="Center"
								   HorizontalAlignment="Right"
								   Foreground="{DynamicResource ThemeText}"
								   FontSize="14"/>

							<Button x:Name="CheckForUpdatesButton"
									Classes="modern-icon"
									Width="28"
									Height="28"
									Margin="12,0,0,0"
									ToolTip.Tip="{Binding CheckForUpdatesToolTip}"
									IsEnabled="{Binding !IsCheckingUpdates}"
									Click="CheckforUpdates_Click">
								<Grid Width="28" Height="28">
									<Image Width="28"
										   Height="28"
										   Source="avares://Quiver/Assets/CheckForUpdates.png"
										   Opacity="{Binding CheckForUpdatesIconOpacity}"/>
									<ProgressBar Height="2"
												 VerticalAlignment="Bottom"
												 IsIndeterminate="True"
												 IsVisible="{Binding IsCheckingUpdates}"/>
									<Border Background="#FF9500"
											CornerRadius="8"
											MinWidth="16"
											Height="16"
											Padding="4,0"
											HorizontalAlignment="Right"
											VerticalAlignment="Top"
											Margin="0,-4,-4,0"
											IsVisible="{Binding UpdatesBadgeVisible}">
										<TextBlock Text="{Binding UpdatesBadgeText}"
												   FontSize="9"
												   FontWeight="Bold"
												   Foreground="White"/>
									</Border>
								</Grid>
							</Button>

							<Button x:Name="SettingsButton"
									Classes="modern-icon"
									Width="28"
									Height="28"
									Margin="8,0,0,0"
									ToolTip.Tip="Settings"
									Click="SettingsButton_Click">
								<Image Width="28" Height="28"
									   Source="avares://Quiver/Assets/Settings.png"/>
							</Button>

							<!-- Minimize Button -->
							<Button Classes="modern-icon"
									Width="28"
									Margin="12,0,0,0"
									Click="MinimizeButton_Click">
								<Image Width="28" 
									   Height="28" 
									   Source="avares://Quiver/Assets/Icons/button_minimize.png"/>
							</Button>

							<!-- Fullscreen Button -->
							<Button Classes="modern-icon"
									Width="28"
									Margin="8,0,0,0"
									Click="ToggleFullscreen_Click">
								<Image Width="28" 
									   Height="28" 
									   Source="avares://Quiver/Assets/Icons/button_fullscreen.png"/>
							</Button>

							<!-- Close Button -->
							<Button Classes="modern-icon"
									Width="28"
									Margin="8,0,10,0"
									Click="CloseLauncher_Click">
								<Image Width="28" 
									   Height="28" 
									   Source="avares://Quiver/Assets/Icons/button_close.png"/>
							</Button>
						</StackPanel>
				</Grid>
			</Border>

			<!-- Apps Content with Settings Panel Overlay -->
			<Grid Grid.Row="1">

				<!-- Background Image -->
				<Border Background="{DynamicResource ThemeDarker}"/>
				<Image x:Name="StaticBackgroundImage"
					Source="{Binding BackgroundImageUri}"
					Stretch="Fill"
					Opacity="{Binding BackgroundOpacity}"/>

				<!-- Main App List -->
				<ScrollViewer x:Name="LibraryContentPanel" VerticalScrollBarVisibility="Auto" Margin="30,20,30,30">
					<Grid>
						<ItemsControl ItemsSource="{Binding Games}" x:Name="ListViewControl"
									  IsVisible="{Binding ElementName=UseGridViewCheckBox, Path=!IsChecked}">
							<ItemsControl.ItemTemplate>
								<StaticResource ResourceKey="ListViewTemplate"/>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<ItemsControl ItemsSource="{Binding Games}" x:Name="ClassicGridViewControl"
									  IsVisible="False">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel Orientation="Horizontal" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<StaticResource ResourceKey="GridViewTemplate"/>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<ItemsControl ItemsSource="{Binding Games}" x:Name="CompactGridViewControl"
									  IsVisible="False">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel Orientation="Horizontal" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<StaticResource ResourceKey="CompactGridViewTemplate"/>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</Grid>
				</ScrollViewer>

				<!-- App Catalog Content -->
				<Grid x:Name="CatalogContentPanel" IsVisible="False" Margin="30,20,30,30">
					<!-- Sources list -->
					<ScrollViewer x:Name="CatalogSourcesPanel" VerticalScrollBarVisibility="Auto">
						<StackPanel Spacing="12" MaxWidth="720" HorizontalAlignment="Left">
							<TextBlock Text="External catalog sources reference remote app lists. Your local apps.json is your library."
									   FontSize="12"
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   TextWrapping="Wrap"/>
							<StackPanel Orientation="Horizontal" Spacing="8">
								<Button Classes="options" Content="Add Source" Click="AddCatalogSource_Click" FontSize="12"/>
								<Button Classes="options" Content="Refresh All Sources" Click="RefreshCatalogSources_Click" FontSize="12"/>
							</StackPanel>
							<ItemsControl ItemsSource="{Binding CatalogSources}">
								<ItemsControl.ItemTemplate>
									<StaticResource ResourceKey="CatalogSourceCardTemplate"/>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
							<TextBlock x:Name="CatalogSourcesEmptyText"
									   Text="No catalog sources yet. Add a source to subscribe to an external app list."
									   FontSize="12"
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   TextWrapping="Wrap"
									   IsVisible="False"/>
						</StackPanel>
					</ScrollViewer>

					<!-- Source review -->
					<Grid x:Name="CatalogReviewPanel" IsVisible="False" RowDefinitions="Auto,Auto,Auto,*">
						<TextBlock x:Name="CatalogReviewVersionText"
								   Grid.Row="0"
								   FontSize="11"
								   Foreground="{DynamicResource ThemeTextSecondary}"
								   TextWrapping="Wrap"
								   Margin="0,0,0,8"/>
						<StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
							<Button x:Name="CatalogSyncAddAllButton" Classes="options" Content="Add all new"
									Click="CatalogSyncAddAll_Click" FontSize="11"/>
							<Button x:Name="CatalogSyncReplaceAllButton" Classes="options" Content="Replace all changed"
									Click="CatalogSyncReplaceAll_Click" FontSize="11"/>
							<Button x:Name="CatalogSyncAcknowledgeButton" Classes="options" Content="Skip &amp; mark reviewed"
									Click="CatalogSyncAcknowledge_Click" FontSize="11" IsVisible="False"/>
						</StackPanel>
						<StackPanel Grid.Row="2" Spacing="8" Margin="0,0,0,8">
							<WrapPanel Orientation="Horizontal">
								<Button x:Name="CatalogFilterAllButton" Classes="catalog-filter selected" Content="All"
										Tag="All" Click="CatalogReviewFilter_Click" Margin="0,0,6,6"/>
								<Button x:Name="CatalogFilterNeedsReviewButton" Classes="catalog-filter" Content="Needs review"
										Tag="NeedsReview" Click="CatalogReviewFilter_Click" Margin="0,0,6,6"/>
								<Button x:Name="CatalogFilterNewButton" Classes="catalog-filter" Content="New"
										Tag="New" Click="CatalogReviewFilter_Click" Margin="0,0,6,6"/>
								<Button x:Name="CatalogFilterNotInLibraryButton" Classes="catalog-filter" Content="Not in library"
										Tag="NotInLibrary" Click="CatalogReviewFilter_Click" Margin="0,0,6,6"/>
								<Button x:Name="CatalogFilterChangedButton" Classes="catalog-filter" Content="Changed"
										Tag="Changed" Click="CatalogReviewFilter_Click" Margin="0,0,6,6"/>
								<Button x:Name="CatalogFilterUpToDateButton" Classes="catalog-filter" Content="Up to date"
										Tag="UpToDate" Click="CatalogReviewFilter_Click" Margin="0,0,6,6"/>
								<Button x:Name="CatalogFilterLocalOnlyButton" Classes="catalog-filter" Content="Local only"
										Tag="LocalOnly" Click="CatalogReviewFilter_Click" Margin="0,0,6,6"/>
								<Button x:Name="CatalogFilterHiddenButton" Classes="catalog-filter" Content="Hidden"
										Tag="Hidden" Click="CatalogReviewFilter_Click" Margin="0,0,6,6"/>
							</WrapPanel>
							<TextBlock Text="New = not in library yet and still needs review. Not in library = all catalog entries you haven't added (including ignored). Ignore skips changes for this catalog version. Hide removes apps from review until unhidden in Hidden."
									   FontSize="10"
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   Opacity="0.85"/>
							<TextBlock Text="Tag colors: amber = local only · green = external only · gray = both"
									   FontSize="10"
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   Opacity="0.85"/>
						</StackPanel>
						<ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
							<StackPanel>
								<StackPanel x:Name="CatalogSyncNeedsReviewEmptyPanel"
											Spacing="12"
											Margin="0,8,0,0"
											IsVisible="False">
									<TextBlock Text="You're all caught up — nothing needs review."
											   FontSize="12"
											   Foreground="{DynamicResource ThemeTextSecondary}"
											   TextWrapping="Wrap"/>
									<StackPanel Orientation="Horizontal" Spacing="8">
										<Button x:Name="CatalogSyncBackToLibraryButton"
												Classes="options"
												Content="Back to Library"
												FontSize="11"
												Click="CatalogSyncBackToLibrary_Click"/>
										<Button x:Name="CatalogSyncBackToSourcesButton"
												Classes="options"
												Content="Back to sources"
												FontSize="11"
												Click="CatalogSyncBackToSources_Click"/>
									</StackPanel>
								</StackPanel>
								<TextBlock x:Name="CatalogSyncEmptyText"
										   Text="No apps match this filter."
										   FontSize="12"
										   Foreground="{DynamicResource ThemeTextSecondary}"
										   TextWrapping="Wrap"
										   IsVisible="False"
										   Margin="0,8,0,0"/>
								<ItemsControl x:Name="CatalogSyncRowsItemsControl"
											  ItemsSource="{Binding CatalogSyncRows}">
									<ItemsControl.ItemTemplate>
										<StaticResource ResourceKey="CatalogReviewCardTemplate"/>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>
						</ScrollViewer>
					</Grid>
				</Grid>

				<!-- Settings Panel Overlay -->
				<Border x:Name="SettingsPanel"
						HorizontalAlignment="Right"
						VerticalAlignment="Stretch"
						Width="400"
						Background="{DynamicResource ThemeDarker}"
						BorderBrush="{DynamicResource ThemeBorder}"
						BorderThickness="1,0,0,0"
						IsVisible="False"
						Opacity="0.97"
						ZIndex="10">
					<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
						<StackPanel x:Name="SettingsContent">

							<!-- Settings Header -->
							<Border Background="{DynamicResource ThemeBase}"
									Padding="20,14,20,14"
									BorderThickness="0,0,0,1"
									BorderBrush="{DynamicResource ThemeBorder}">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>
									<TextBlock Grid.Column="0"
											   Text="Settings"
											   FontSize="20"
											   FontWeight="Bold"
											   Foreground="{DynamicResource ThemeText}"
											   VerticalAlignment="Center"/>
									<Button Grid.Column="1"
											Classes="modern-icon"
											Width="28"
											Height="28"
											ToolTip.Tip="Close settings"
											Click="CloseSettingsPanel_Click">
										<Image Width="28"
											   Height="28"
											   Source="avares://Quiver/Assets/Icons/button_close.png"/>
									</Button>
								</Grid>
							</Border>

							<!-- Tab Control -->
							<TabControl Background="Transparent"
										Foreground="{DynamicResource ThemeText}"
										Padding="8,4,8,0"
										Margin="0">

								<!-- General Tab -->
								<TabItem Header="General">
									<StackPanel Margin="16,12,16,16" Spacing="4">

										<!-- Behaviour -->
										<TextBlock Text="BEHAVIOUR"
												   FontSize="10" FontWeight="Bold"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   LetterSpacing="1"
												   Margin="0,0,0,4"/>

										<StackPanel Spacing="2">
											<CheckBox x:Name="EnableGamepadCheckBox"
													  Content="Enable Gamepad Input"
													  Foreground="{DynamicResource ThemeText}"
													  FontSize="13" FontWeight="SemiBold"
													  Checked="EnableGamepadCheckBox_Checked"
													  Unchecked="EnableGamepadCheckBox_Unchecked"/>
											<TextBlock Text="Allow controller navigation inside the launcher"
													   FontSize="11"
													   Foreground="{DynamicResource ThemeTextSecondary}"
													   Margin="20,0,0,0"/>
										</StackPanel>

										<StackPanel Spacing="2">
											<CheckBox x:Name="CloseAfterLaunchCheckBox"
													  Content="Close After Launch"
													  Foreground="{DynamicResource ThemeText}"
													  FontSize="13" FontWeight="SemiBold"
													  Checked="CloseAfterLaunchCheckBox_Checked"
													  Unchecked="CloseAfterLaunchCheckBox_Unchecked"/>
											<TextBlock Text="Close the launcher automatically after starting an app"
													   FontSize="11"
													   Foreground="{DynamicResource ThemeTextSecondary}"
													   Margin="20,0,0,0"/>
										</StackPanel>

										<!-- Divider -->
										<Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,8,0,8"/>

										<!-- Install Path -->
										<TextBlock Text="APP INSTALL PATH"
												   FontSize="10" FontWeight="Bold"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   LetterSpacing="1"
												   Margin="0,0,0,4"/>

										<TextBlock Text="Leave blank to use the default location"
												   FontSize="11"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   Margin="0,0,0,4"/>

										<Panel HorizontalAlignment="Stretch">
											<TextBox x:Name="GamePathTextBox"
													 Foreground="{DynamicResource ThemeText}"
													 Background="{DynamicResource ThemeBase}"
													 BorderBrush="{DynamicResource ThemeBorder}"
													 BorderThickness="1"
													 Padding="12,10"
													 CornerRadius="4"
													 Margin="0,0,44,0"
													 TextChanged="GamePathTextBox_TextChanged"
													 Text="{Binding Settings.GamesPath, Mode=TwoWay}"/>
											<Button Classes="options"
													HorizontalAlignment="Right"
													Width="40"
													Height="40"
													Content="📁"
													Click="BrowseGamePath_Click"/>
										</Panel>

										<Button Classes="options"
												Content="Reset to Default"
												HorizontalAlignment="Stretch"
												Click="ClearGamePath_Click"
												FontSize="12"/>

										<!-- Divider -->
										<Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,8,0,8"/>

										<!-- Platform & Cache -->
										<TextBlock Text="PLATFORM &amp; CACHE"
												   FontSize="10" FontWeight="Bold"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   LetterSpacing="1"
												   Margin="0,0,0,4"/>

										<TextBlock Text="{Binding PlatformString}"
												   FontSize="11"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   Margin="0,0,0,4"/>

										<Button Classes="options"
												Content="Change Platform"
												HorizontalAlignment="Stretch"
												Click="OptionsButton_Click"
												Tag="{Binding}"
												FontSize="12">
											<Button.ContextMenu>
												<ContextMenu>
													<MenuItem Header="Automatic"   Click="PlatformAuto_Click"/>
													<MenuItem Header="Windows"     Click="PlatformWindows_Click"/>
													<MenuItem Header="MacOS"       Click="PlatformMacOS_Click"/>
													<MenuItem Header="Linux X64"   Click="PlatformLinuxX64_Click"/>
													<MenuItem Header="Linux ARM64" Click="PlatformLinuxARM64_Click"/>
												</ContextMenu>
											</Button.ContextMenu>
										</Button>

										<Button Classes="options"
												Content="Clear Icon Cache"
												HorizontalAlignment="Stretch"
												Click="ClearIconCache_Click"
												FontSize="12"/>

										<StackPanel Spacing="2" IsVisible="{Binding IsLinuxPlatform}">
											<TextBlock Text="LINUX WINDOWS RUNNER"
													   FontSize="10" FontWeight="Bold"
													   Foreground="{DynamicResource ThemeTextSecondary}"
													   LetterSpacing="1"
													   Margin="0,8,0,4"/>
											<TextBox x:Name="LinuxWindowsLaunchCommandTextBox"
													 Foreground="{DynamicResource ThemeText}"
													 Background="{DynamicResource ThemeBase}"
													 BorderBrush="{DynamicResource ThemeBorder}"
													 BorderThickness="1"
													 Padding="12,10"
													 CornerRadius="4"
													 Watermark="Example: flatpak run com.usebottles.bottles -e {exe}"
													 Text="{Binding Settings.LinuxWindowsLaunchCommand, Mode=TwoWay}"
													 TextChanged="LinuxWindowsLaunchCommandTextBox_TextChanged"/>
											<TextBlock Text="Optional override for Windows-only apps on Linux. Use {exe}, {appPath}, or {exeDir}. Leave blank to auto-detect Wine/Proton."
													   FontSize="11"
													   TextWrapping="Wrap"
													   Foreground="{DynamicResource ThemeTextSecondary}"
													   Margin="0,0,0,4"/>
										</StackPanel>

									</StackPanel>
								</TabItem>

								<!-- Appearance Tab -->
								<TabItem Header="Appearance">
									<StackPanel Margin="16,12,16,16" Spacing="4">

										<!-- Window -->
										<TextBlock Text="WINDOW"
												   FontSize="10" FontWeight="Bold"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   LetterSpacing="1"
												   Margin="0,0,0,4"/>

										<StackPanel Spacing="2">
											<CheckBox x:Name="StartFullscreenCheckBox"
													  Content="Start in Fullscreen"
													  Foreground="{DynamicResource ThemeText}"
													  FontSize="13" FontWeight="SemiBold"
													  Checked="StartFullscreenCheckBox_Checked"
													  Unchecked="StartFullscreenCheckBox_Unchecked"/>
											<TextBlock Text="Launch the application in fullscreen mode"
													   FontSize="11"
													   Foreground="{DynamicResource ThemeTextSecondary}"
													   Margin="20,0,0,0"/>
										</StackPanel>

										<StackPanel Spacing="2">
											<CheckBox x:Name="RoundWindowCornersCheckBox"
													  Content="Rounded Window Corners"
													  Foreground="{DynamicResource ThemeText}"
													  FontSize="13" FontWeight="SemiBold"
													  Checked="RoundWindowCornersCheckBox_Checked"
													  Unchecked="RoundWindowCornersCheckBox_Unchecked"/>
											<TextBlock Text="Apply rounded corners to the launcher window"
													   FontSize="11"
													   Foreground="{DynamicResource ThemeTextSecondary}"
													   Margin="20,0,0,0"/>
										</StackPanel>

										<StackPanel Spacing="2">
											<CheckBox x:Name="ShowOSTopBarCheckBox"
													  Content="Show OS Top Bar"
													  Foreground="{DynamicResource ThemeText}"
													  FontSize="13" FontWeight="SemiBold"
													  Checked="ShowOSTopBarCheckBox_Checked"
													  Unchecked="ShowOSTopBarCheckBox_Unchecked"/>
											<TextBlock Text="Display your operating system's title bar"
													   FontSize="11"
													   Foreground="{DynamicResource ThemeTextSecondary}"
													   Margin="20,0,0,0"/>
										</StackPanel>

										<!-- Divider -->
										<Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,8,0,8"/>

										<!-- Theme Colors -->
										<TextBlock Text="THEME COLORS"
												   FontSize="10" FontWeight="Bold"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   LetterSpacing="1"
												   Margin="0,0,0,4"/>

										<Button Classes="options"
												Content="Primary Color"
												HorizontalAlignment="Stretch"
												Click="ThemeColorPicker_Click"
												FontSize="12"/>
										<Button Classes="options"
												Content="Secondary Color"
												HorizontalAlignment="Stretch"
												Click="SecondaryColorPicker_Click"
												FontSize="12"/>

										<!-- Divider -->
										<Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,8,0,8"/>

										<!-- Background Image -->
										<TextBlock Text="BACKGROUND IMAGE"
												   FontSize="10" FontWeight="Bold"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   LetterSpacing="1"
												   Margin="0,0,0,4"/>

										<TextBlock Text="PNG, JPG, and GIF formats supported"
												   FontSize="11"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   Margin="0,0,0,4"/>

										<Button Classes="options"
												Content="Select Image"
												HorizontalAlignment="Stretch"
												Click="SelectBackgroundImage_Click"
												FontSize="12"/>
										<Button Classes="options"
												Content="Clear Background"
												HorizontalAlignment="Stretch"
												Click="ClearBackgroundImage_Click"
												IsEnabled="{Binding BackgroundImagePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
												FontSize="12"/>

										<StackPanel Spacing="4" Margin="0,4,0,0">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="Opacity:"
														   FontSize="12"
														   Foreground="{DynamicResource ThemeText}"
														   VerticalAlignment="Center"/>
												<TextBlock Text="{Binding ElementName=BackgroundOpacitySlider, Path=Value, StringFormat={}{0:F2}}"
														   FontSize="12"
														   Foreground="{DynamicResource ThemeTextSecondary}"/>
											</StackPanel>
											<Slider x:Name="BackgroundOpacitySlider"
													Minimum="0" Maximum="1"
													Value="{Binding BackgroundOpacity}"
													TickFrequency="0.01"
													IsSnapToTickEnabled="True"
													ValueChanged="BackgroundOpacitySlider_ValueChanged"/>
										</StackPanel>

										<!-- Divider -->
										<Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,8,0,8"/>

										<!-- Background Music -->
										<TextBlock Text="BACKGROUND MUSIC"
												   FontSize="10" FontWeight="Bold"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   LetterSpacing="1"
												   Margin="0,0,0,4"/>

										<TextBlock Text="MP3, WAV, and OGG formats supported"
												   FontSize="11"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   Margin="0,0,0,4"/>

										<Button Classes="options"
												Content="Select Music"
												HorizontalAlignment="Stretch"
												Click="SelectLauncherMusic_Click"
												FontSize="12"/>
										<Button Classes="options"
												Content="Clear Music"
												HorizontalAlignment="Stretch"
												Click="ClearLauncherMusic_Click"
												IsEnabled="{Binding LauncherMusicPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
												FontSize="12"/>

										<StackPanel Spacing="4" Margin="0,4,0,0">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="Volume:"
														   FontSize="12"
														   Foreground="{DynamicResource ThemeText}"
														   VerticalAlignment="Center"/>
												<TextBlock Text="{Binding ElementName=MusicVolumeSlider, Path=Value, StringFormat={}{0:F2}}"
														   FontSize="12"
														   Foreground="{DynamicResource ThemeTextSecondary}"/>
											</StackPanel>
											<Slider x:Name="MusicVolumeSlider"
													Minimum="0" Maximum="1"
													Value="{Binding MusicVolume}"
													TickFrequency="0.01"
													IsSnapToTickEnabled="True"
													ValueChanged="MusicVolumeSlider_ValueChanged"/>
										</StackPanel>

									</StackPanel>
								</TabItem>

								<!-- App Cards Tab -->
								<TabItem Header="App Cards">
									<StackPanel Margin="16,12,16,16" Spacing="4">

										<!-- Layout -->
										<TextBlock Text="LAYOUT"
												   FontSize="10" FontWeight="Bold"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   LetterSpacing="1"
												   Margin="0,0,0,4"/>

										<StackPanel Spacing="2">
											<CheckBox x:Name="UseGridViewCheckBox"
													  Content="Grid View"
													  Foreground="{DynamicResource ThemeText}"
													  FontSize="13" FontWeight="SemiBold"
													  Checked="UseGridViewCheckBox_Checked"
													  Unchecked="UseGridViewCheckBox_Unchecked"/>
											<TextBlock Text="Display apps in a grid instead of a list"
													   FontSize="11"
													   Foreground="{DynamicResource ThemeTextSecondary}"
													   Margin="20,0,0,0"/>
										</StackPanel>

										<StackPanel Spacing="2" Margin="0,4,0,0">
											<CheckBox x:Name="GridCompactCardsCheckBox"
													  Content="Details in card"
													  Foreground="{DynamicResource ThemeText}"
													  FontSize="13" FontWeight="SemiBold"
													  IsEnabled="{Binding ElementName=UseGridViewCheckBox, Path=IsChecked}"
													  Checked="GridCompactCardsCheckBox_Checked"
													  Unchecked="GridCompactCardsCheckBox_Unchecked"/>
											<TextBlock Text="Keep name, status, and buttons inside each grid card"
													   FontSize="11"
													   Foreground="{DynamicResource ThemeTextSecondary}"
													   Margin="20,0,0,0"/>
										</StackPanel>

										<StackPanel Spacing="6" Margin="0,4,0,0">
											<TextBlock Text="Presets"
													   FontSize="11"
													   Foreground="{DynamicResource ThemeTextSecondary}"/>
											<StackPanel Orientation="Horizontal" Spacing="8">
												<Button Classes="modern-icon" Width="52" Height="52"
														Click="LayoutPreset_Landscape_Click"
														ToolTip.Tip="Landscape">
													<Image Width="52" Height="52" Source="avares://Quiver/Assets/Icons/preset_landscape.png"/>
												</Button>
												<Button Classes="modern-icon" Width="52" Height="52"
														Click="LayoutPreset_Square_Click"
														ToolTip.Tip="Square">
													<Image Width="52" Height="52" Source="avares://Quiver/Assets/Icons/preset_square.png"/>
												</Button>
												<Button Classes="modern-icon" Width="52" Height="52"
														Click="LayoutPreset_Portrait_Click"
														ToolTip.Tip="Portrait">
													<Image Width="52" Height="52" Source="avares://Quiver/Assets/Icons/preset_portrait.png"/>
												</Button>
												<Button Classes="modern-icon" Width="52" Height="52"
														Click="LayoutPreset_List_Click"
														ToolTip.Tip="List">
													<Image Width="52" Height="52" Source="avares://Quiver/Assets/Icons/preset_list.png"/>
												</Button>
											</StackPanel>
										</StackPanel>

										<!-- Divider -->
										<Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,8,0,8"/>

										<!-- Card Size -->
										<TextBlock Text="CARD SIZE"
												   FontSize="10" FontWeight="Bold"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   LetterSpacing="1"
												   Margin="0,0,0,4"/>

										<StackPanel Spacing="4">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="Size:"
														   FontSize="12"
														   Foreground="{DynamicResource ThemeText}"
														   VerticalAlignment="Center"/>
												<TextBlock Text="{Binding ElementName=SlotSizeSlider, Path=Value, StringFormat={}{0:0}}"
														   FontSize="12"
														   Foreground="{DynamicResource ThemeTextSecondary}"/>
											</StackPanel>
											<Slider x:Name="SlotSizeSlider"
													Minimum="120" Maximum="400"
													Value="152"
													TickFrequency="4"
													IsSnapToTickEnabled="True"
													ValueChanged="SlotSizeSlider_ValueChanged"/>
										</StackPanel>

										<!-- Divider -->
										<Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,8,0,8"/>

										<!-- Action Buttons -->
										<TextBlock Text="ACTION BUTTONS"
												   FontSize="10" FontWeight="Bold"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   LetterSpacing="1"
												   Margin="0,0,0,4"/>

										<StackPanel Spacing="4">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="Size:"
														   FontSize="12"
														   Foreground="{DynamicResource ThemeText}"
														   VerticalAlignment="Center"/>
												<TextBlock Text="{Binding ElementName=ActionButtonSizeSlider, Path=Value, StringFormat={}{0:0}}"
														   FontSize="12"
														   Foreground="{DynamicResource ThemeTextSecondary}"/>
											</StackPanel>
											<Slider x:Name="ActionButtonSizeSlider"
													Minimum="32" Maximum="80"
													Value="36"
													TickFrequency="4"
													IsSnapToTickEnabled="True"
													ValueChanged="ActionButtonSizeSlider_ValueChanged"/>
											<TextBlock Text="Size of Play, Download, and Update buttons"
													   FontSize="11"
													   Foreground="{DynamicResource ThemeTextSecondary}"/>
										</StackPanel>

										<!-- Divider -->
										<Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,8,0,8"/>

										<!-- App Images -->
										<TextBlock Text="GAME IMAGES"
												   FontSize="10" FontWeight="Bold"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   LetterSpacing="1"
												   Margin="0,0,0,4"/>

										<!-- Size -->
										<StackPanel Spacing="4">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="Size:"
														   FontSize="12"
														   Foreground="{DynamicResource ThemeText}"
														   VerticalAlignment="Center"/>
												<TextBlock Text="{Binding ElementName=IconSizeSlider, Path=Value, StringFormat={}{0:0}}"
														   FontSize="11"
														   Foreground="{DynamicResource ThemeTextSecondary}"/>
											</StackPanel>
											<Slider x:Name="IconSizeSlider"
													Minimum="64" Maximum="512"
													Value="124"
													TickFrequency="4"
													IsSnapToTickEnabled="True"
													ValueChanged="IconSizeSlider_ValueChanged"/>
										</StackPanel>

										<!-- Custom Image Fill -->
										<StackPanel Spacing="2">
											<CheckBox x:Name="IconFillCheckBox"
													  Content="Fill Cards"
													  IsChecked="False"
													  Foreground="{DynamicResource ThemeText}"
													  FontSize="13" FontWeight="SemiBold"
													  Checked="IconFillCheckBox_Checked"
													  Unchecked="IconFillCheckBox_Unchecked"/>
											<TextBlock Text="Stretch images to fill entire cards"
													   FontSize="11"
													   Foreground="{DynamicResource ThemeTextSecondary}"
													   Margin="20,0,0,0"/>
										</StackPanel>

										<!-- Image Opacity -->
										<StackPanel Spacing="4">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="Card Image Opacity:"
														   FontSize="12"
														   Foreground="{DynamicResource ThemeText}"
														   VerticalAlignment="Center"/>
												<TextBlock Text="{Binding ElementName=IconOpacitySlider, Path=Value, StringFormat={}{0:F1}}"
														   FontSize="11"
														   Foreground="{DynamicResource ThemeTextSecondary}"/>
											</StackPanel>
											<Slider x:Name="IconOpacitySlider"
													Minimum="0.0" Maximum="1.0"
													Value="0.2"
													TickFrequency="0.1"
													IsSnapToTickEnabled="True"
													ValueChanged="IconOpacitySlider_ValueChanged"/>
											<TextBlock Text="Control image transparency"
													   FontSize="11"
													   Foreground="{DynamicResource ThemeTextSecondary}"/>
										</StackPanel>

										<!-- Left Padding -->
										<StackPanel Spacing="4">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="Left Padding:"
														   FontSize="12"
														   Foreground="{DynamicResource ThemeText}"
														   VerticalAlignment="Center"/>
												<TextBlock Text="{Binding ElementName=IconMarginSlider, Path=Value, StringFormat={}{0:0}}"
														   FontSize="11"
														   Foreground="{DynamicResource ThemeTextSecondary}"/>
											</StackPanel>
											<Slider x:Name="IconMarginSlider"
													Minimum="0" Maximum="512"
													Value="0"
													TickFrequency="8"
													IsSnapToTickEnabled="True"
													ValueChanged="IconMarginSlider_ValueChanged"/>
										</StackPanel>

										<!-- Divider -->
										<Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,8,0,8"/>

										<!-- Text -->
										<TextBlock Text="TEXT"
												   FontSize="10" FontWeight="Bold"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   LetterSpacing="1"
												   Margin="0,0,0,4"/>

										<StackPanel Spacing="4">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="Text Padding:"
														   FontSize="12"
														   Foreground="{DynamicResource ThemeText}"
														   VerticalAlignment="Center"/>
												<TextBlock Text="{Binding ElementName=TextMarginSlider, Path=Value, StringFormat={}{0:0}}"
														   FontSize="12"
														   Foreground="{DynamicResource ThemeTextSecondary}"/>
											</StackPanel>
											<Slider x:Name="TextMarginSlider"
													Minimum="0" Maximum="256"
													Value="0"
													TickFrequency="8"
													IsSnapToTickEnabled="True"
													ValueChanged="TextMarginSlider_ValueChanged"/>
											<TextBlock Text="Adjust the left spacing of text labels"
													   FontSize="11"
													   Foreground="{DynamicResource ThemeTextSecondary}"/>
										</StackPanel>

									</StackPanel>
								</TabItem>

								<!-- Advanced Tab -->
								<TabItem Header="Advanced">
									<StackPanel Margin="16,12,16,16" Spacing="4">

										<!-- GitHub API Token -->
										<TextBlock Text="GITHUB API TOKEN"
												   FontSize="10" FontWeight="Bold"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   LetterSpacing="1"
												   Margin="0,0,0,4"/>

										<TextBlock Text="Increases API rate limits for faster and more reliable downloads"
												   FontSize="11"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   TextWrapping="Wrap"
												   Margin="0,0,0,6"/>

										<TextBox x:Name="GitHubTokenTextBox"
												 Foreground="{DynamicResource ThemeText}"
												 Background="{DynamicResource ThemeBase}"
												 BorderBrush="{DynamicResource ThemeBorder}"
												 BorderThickness="1"
												 Padding="12,10"
												 CornerRadius="4"
												 TextChanged="GitHubTokenTextBox_TextChanged"
												 Text="{Binding Settings.GitHubApiToken, Mode=TwoWay}"/>

										<Button Classes="options"
												Content="Create GitHub Token"
												HorizontalAlignment="Stretch"
												Click="CreateGitHubToken_Click"
												FontSize="12"/>

										<Button Classes="options"
												Content="Clear Token"
												HorizontalAlignment="Stretch"
												Click="ClearGitHubToken_Click"
												FontSize="12"/>

										<Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,8,0,8"/>

										<TextBlock Text="Visit GitHub's token documentation for more information on generating a personal access token."
												   FontSize="10"
												   Foreground="{DynamicResource ThemeTextSecondary}"
												   FontStyle="Italic"
												   TextWrapping="Wrap"/>

									</StackPanel>
								</TabItem>

							</TabControl>
						</StackPanel>
					</ScrollViewer>
				</Border>
				
				<!-- Changelog Panel -->
				<Border x:Name="ChangelogPanel"
						Grid.RowSpan="2"
						Background="{DynamicResource ThemeBase}"
						IsVisible="False"
						ZIndex="100">
					<Grid>
						<ScrollViewer VerticalScrollBarVisibility="Auto"
									  Margin="40">
							<StackPanel MaxWidth="900">
								<TextBlock x:Name="ChangelogTitle"
										   Text="Changelog"
										   FontSize="28"
										   FontWeight="Bold"
										   Foreground="{DynamicResource ThemeText}"
										   Margin="0,0,0,20"/>
								<ItemsControl x:Name="ChangelogContent"
											  ItemsSource="{Binding}">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<ContentControl Content="{Binding}"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>
						</ScrollViewer>
					</Grid>
				</Border>

				<!-- Entry Form Overlay -->
				<Border x:Name="EntryFormOverlay"
						Grid.RowSpan="2"
						Background="{DynamicResource ThemeBase}"
						IsVisible="False"
						ZIndex="100">
					<ScrollViewer VerticalScrollBarVisibility="Auto" Margin="40">
						<StackPanel Spacing="20" MinWidth="640" MaxWidth="960" HorizontalAlignment="Center">
							<Border Background="{DynamicResource ThemeDarker}"
									BorderBrush="{DynamicResource ThemeBorder}"
									BorderThickness="1"
									CornerRadius="8"
									Padding="16">
								<StackPanel Spacing="12">
									<TextBlock x:Name="FormTitleText"
											   Text="Create New Entry"
											   FontSize="18"
											   FontWeight="Bold"
											   Foreground="{DynamicResource ThemeText}"/>
									<Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,4,0,8"/>

									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="130"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>
										<Grid.RowDefinitions>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
										</Grid.RowDefinitions>

										<TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Foreground="{DynamicResource ThemeTextSecondary}"/>
										<TextBox Grid.Row="0" Grid.Column="1"
												 x:Name="NewGameNameTextBox"
												 Foreground="{DynamicResource ThemeText}"
												 Background="{DynamicResource ThemeBase}"
												 BorderBrush="{DynamicResource ThemeBorder}"
												 BorderThickness="1"
												 CornerRadius="4"
												 Padding="8"
												 Margin="8,0,0,8"
												 TextChanged="GameNameTextBox_TextChanged"/>

										<TextBlock Grid.Row="1" Grid.Column="0" Text="Repository:" VerticalAlignment="Center" Foreground="{DynamicResource ThemeTextSecondary}"/>
										<TextBox Grid.Row="1" Grid.Column="1"
												 x:Name="NewGameRepoTextBox"
												 Foreground="{DynamicResource ThemeText}"
												 Background="{DynamicResource ThemeBase}"
												 BorderBrush="{DynamicResource ThemeBorder}"
												 BorderThickness="1"
												 CornerRadius="4"
												 Padding="8"
												 Margin="8,0,0,8"
												 TextChanged="GameRepoTextBox_TextChanged"/>

										<TextBlock Grid.Row="2" Grid.Column="0" Text="Folder Name:" VerticalAlignment="Center" Foreground="{DynamicResource ThemeTextSecondary}"/>
										<TextBox Grid.Row="2" Grid.Column="1"
												 x:Name="NewGameFolderTextBox"
												 Foreground="{DynamicResource ThemeText}"
												 Background="{DynamicResource ThemeBase}"
												 BorderBrush="{DynamicResource ThemeBorder}"
												 BorderThickness="1"
												 CornerRadius="4"
												 Padding="8"
												 Margin="8,0,0,8"
												 TextChanged="GameFolderTextBox_TextChanged"/>

										<TextBlock Grid.Row="3" Grid.Column="0" Text="Tags:" VerticalAlignment="Center" Foreground="{DynamicResource ThemeTextSecondary}"/>
										<TextBox Grid.Row="3" Grid.Column="1"
												 x:Name="NewGameTagsTextBox"
												 Watermark="e.g. n64, recomp"
												 Foreground="{DynamicResource ThemeText}"
												 Background="{DynamicResource ThemeBase}"
												 BorderBrush="{DynamicResource ThemeBorder}"
												 BorderThickness="1"
												 CornerRadius="4"
												 Padding="8"
												 Margin="8,0,0,8"/>

										<TextBlock Grid.Row="4" Grid.Column="0" Text="Icon URL:" VerticalAlignment="Center" Foreground="{DynamicResource ThemeTextSecondary}"/>
										<TextBox Grid.Row="4" Grid.Column="1"
												 x:Name="NewGameIconTextBox"
												 Foreground="{DynamicResource ThemeText}"
												 Background="{DynamicResource ThemeBase}"
												 BorderBrush="{DynamicResource ThemeBorder}"
												 BorderThickness="1"
												 CornerRadius="4"
												 Padding="8"
												 Margin="8,0,0,0"
												 TextChanged="GameIconTextBox_TextChanged"/>
									</Grid>

									<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
										<Button x:Name="CancelButton"
												Classes="options"
												Content="Cancel"
												FontSize="12"
												Width="100"
												Click="CancelForm_Click"/>
										<Button x:Name="CreateEditButton"
												Classes="options"
												Content="Create Entry"
												FontSize="12"
												Width="120"
												Click="CreateNewEntry_Click"/>
									</StackPanel>
								</StackPanel>
							</Border>

							<Border x:Name="ValidationStatusBorder"
									Background="{DynamicResource ThemeDarker}"
									BorderBrush="{DynamicResource ThemeBorder}"
									BorderThickness="1"
									CornerRadius="8"
									Padding="12"
									IsVisible="False">
								<TextBlock x:Name="ValidationStatusText"
										   Text=""
										   Foreground="{DynamicResource ThemeText}"
										   FontSize="12"
										   TextWrapping="Wrap"/>
							</Border>
						</StackPanel>
					</ScrollViewer>
				</Border>

				<!-- Display Filter Overlay -->
				<Border x:Name="DisplayFilterOverlay"
						Grid.RowSpan="2"
						Background="#CC000000"
						IsVisible="False"
						ZIndex="110">
					<Border Background="{DynamicResource ThemeDarker}"
							BorderBrush="{DynamicResource ThemeBorder}"
							BorderThickness="1"
							CornerRadius="8"
							Padding="20"
							MaxWidth="480"
							HorizontalAlignment="Center"
							VerticalAlignment="Center">
						<StackPanel Spacing="12">
							<TextBlock x:Name="DisplayFilterOverlayTitle"
									   Text="Add Display Filter"
									   FontSize="18"
									   FontWeight="Bold"
									   Foreground="{DynamicResource ThemeText}"/>
							<TextBox x:Name="DisplayFilterNameTextBox"
									 Watermark="Filter name"
									 Foreground="{DynamicResource ThemeText}"
									 Background="{DynamicResource ThemeBase}"
									 BorderBrush="{DynamicResource ThemeBorder}"
									 BorderThickness="1"
									 CornerRadius="4"
									 Padding="8"/>
							<TextBlock Text="Include tags"
									   FontSize="13"
									   FontWeight="SemiBold"
									   Foreground="{DynamicResource ThemeText}"/>
							<TextBox x:Name="DisplayFilterTagsTextBox"
									 Watermark="Tags (comma-separated, e.g. n64, favorites)"
									 Foreground="{DynamicResource ThemeText}"
									 Background="{DynamicResource ThemeBase}"
									 BorderBrush="{DynamicResource ThemeBorder}"
									 BorderThickness="1"
									 CornerRadius="4"
									 Padding="8"/>
							<TextBlock Text="Include match mode"
									   FontSize="13"
									   FontWeight="SemiBold"
									   Foreground="{DynamicResource ThemeText}"/>
							<ComboBox x:Name="DisplayFilterMatchModeComboBox"
									  SelectionChanged="DisplayFilterMatchModeComboBox_SelectionChanged">
								<ComboBoxItem Content="Any tag"/>
								<ComboBoxItem Content="All tags"/>
							</ComboBox>
							<TextBlock x:Name="DisplayFilterMatchModeHelpText"
									   FontSize="11"
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   TextWrapping="Wrap"/>
							<TextBlock Text="Exclude tags"
									   FontSize="13"
									   FontWeight="SemiBold"
									   Foreground="{DynamicResource ThemeText}"/>
							<TextBox x:Name="DisplayFilterExcludeTagsTextBox"
									 Watermark="Tags to hide (comma-separated, optional, e.g. ai)"
									 Foreground="{DynamicResource ThemeText}"
									 Background="{DynamicResource ThemeBase}"
									 BorderBrush="{DynamicResource ThemeBorder}"
									 BorderThickness="1"
									 CornerRadius="4"
									 Padding="8"/>
							<TextBlock Text="Exclude match mode"
									   FontSize="13"
									   FontWeight="SemiBold"
									   Foreground="{DynamicResource ThemeText}"/>
							<ComboBox x:Name="DisplayFilterExcludeMatchModeComboBox"
									  SelectionChanged="DisplayFilterExcludeMatchModeComboBox_SelectionChanged">
								<ComboBoxItem Content="Any tag"/>
								<ComboBoxItem Content="All tags"/>
							</ComboBox>
							<TextBlock x:Name="DisplayFilterExcludeMatchModeHelpText"
									   FontSize="11"
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   TextWrapping="Wrap"/>
							<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
								<Button Classes="options"
										Content="Cancel"
										Width="100"
										Click="CancelDisplayFilterEdit_Click"/>
								<Button Classes="options"
										Content="Save"
										Width="100"
										Click="SaveDisplayFilter_Click"/>
							</StackPanel>
						</StackPanel>
					</Border>
				</Border>

				<!-- Tag Edit Overlay -->
				<Border x:Name="TagEditOverlay"
						Grid.RowSpan="2"
						Background="#CC000000"
						IsVisible="False"
						ZIndex="110">
					<Border Background="{DynamicResource ThemeDarker}"
							BorderBrush="{DynamicResource ThemeBorder}"
							BorderThickness="1"
							CornerRadius="8"
							Padding="20"
							MaxWidth="480"
							HorizontalAlignment="Center"
							VerticalAlignment="Center">
						<StackPanel Spacing="12">
							<TextBlock Text="Edit Tags"
									   FontSize="18"
									   FontWeight="Bold"
									   Foreground="{DynamicResource ThemeText}"/>
							<TextBlock x:Name="TagEditAppNameText"
									   FontSize="13"
									   Foreground="{DynamicResource ThemeTextSecondary}"
									   TextWrapping="Wrap"/>
							<TextBox x:Name="TagEditTextBox"
									 Watermark="Tags (comma-separated)"
									 Foreground="{DynamicResource ThemeText}"
									 Background="{DynamicResource ThemeBase}"
									 BorderBrush="{DynamicResource ThemeBorder}"
									 BorderThickness="1"
									 CornerRadius="4"
									 Padding="8"/>
							<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
								<Button Classes="options"
										Content="Cancel"
										Width="100"
										Click="CancelTagEdit_Click"/>
								<Button Classes="options"
										Content="Save"
										Width="100"
										Click="SaveTagEdit_Click"/>
							</StackPanel>
						</StackPanel>
					</Border>
				</Border>

			</Grid>
		</Grid>
	</Grid>
  </Border>
</Window>
