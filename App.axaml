<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Quiver.App"
             RequestedThemeVariant="Dark">

	<Application.Resources>
		<SolidColorBrush x:Key="ThemeBase" Color="#18181b"/>
		<SolidColorBrush x:Key="ThemeLighter" Color="#252527"/>
		<SolidColorBrush x:Key="ThemeDarker" Color="#0e0e10"/>
		<SolidColorBrush x:Key="ThemeBorder" Color="#2d2d30"/>
		<SolidColorBrush x:Key="ThemeText" Color="White"/>
		<SolidColorBrush x:Key="ThemeTextSecondary" Color="#B8B8B8"/>
		<SolidColorBrush x:Key="ThemeSuccess" Color="#22c55e"/>
		<SolidColorBrush x:Key="ThemeWarning" Color="#f59e0b"/>
		<SolidColorBrush x:Key="ThemeError" Color="#ef4444"/>
		<SolidColorBrush x:Key="ThemeAccent" Color="#f59e0b"/>
		<SolidColorBrush x:Key="ThemeFocusRing" Color="#f59e0b"/>
	</Application.Resources>

	<Application.Styles>
		<FluentTheme />

		<Style Selector="ContextMenu">
			<Setter Property="Background" Value="{DynamicResource ThemeBase}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="4"/>
			<Setter Property="CornerRadius" Value="8"/>
		</Style>

		<Style Selector="MenuItem">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
			<Setter Property="Padding" Value="10,8"/>
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
		</Style>

		<Style Selector="MenuItem:selected">
			<Setter Property="Background" Value="{DynamicResource ThemeLighter}"/>
		</Style>

		<!-- Orange :focus rings only under nav chrome; :focus-visible stays for Tab. -->
		<Style Selector="Window.gamepad-chrome MenuItem:focus">
			<Setter Property="Background" Value="{DynamicResource ThemeLighter}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
			<Setter Property="BorderThickness" Value="2"/>
		</Style>

		<Style Selector="MenuItem:focus-visible">
			<Setter Property="Background" Value="{DynamicResource ThemeLighter}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
			<Setter Property="BorderThickness" Value="2"/>
		</Style>

		<Style Selector="Window.gamepad-chrome Button:focus">
			<Setter Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
			<Setter Property="BorderThickness" Value="2"/>
		</Style>

		<Style Selector="Window Button:focus-visible">
			<Setter Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
			<Setter Property="BorderThickness" Value="2"/>
		</Style>

		<!-- Orange gamepad/keyboard rings when Window has class gamepad-chrome. -->
		<Style Selector="Window.gamepad-chrome Button.gamepad-focused /template/ Border">
			<Setter Property="BorderBrush" Value="{DynamicResource ThemeFocusRing}"/>
			<Setter Property="BorderThickness" Value="2"/>
		</Style>

		<Style Selector="Window.gamepad-chrome TextBox.gamepad-focused /template/ Border#PART_BorderElement">
			<Setter Property="BorderBrush" Value="{DynamicResource ThemeFocusRing}"/>
			<Setter Property="BorderThickness" Value="2"/>
		</Style>

		<Style Selector="Window.gamepad-chrome CheckBox.gamepad-focused /template/ Border#NormalRectangle">
			<Setter Property="BorderBrush" Value="{DynamicResource ThemeFocusRing}"/>
			<Setter Property="BorderThickness" Value="2"/>
		</Style>
	</Application.Styles>
</Application>
